import streamlit as st
import yfinance as yf
import pandas as pd
import numpy as np
from datetime import datetime

st.set_page_config(page_title="IA Trader Pro", layout="wide")

st.title("🤖 IA Trader Pro")
st.markdown("### Sinais para Opções Binárias & Forex")

st.sidebar.header("⚙️ Configurações")

ativo = st.sidebar.text_input("Código do Ativo", "BTC-USD", help="Ex: BTC-USD, PETR4.SA, EURUSD=X")

tempo_exp = st.sidebar.selectbox("Tempo de Expiração", 
    ["5 minutos", "15 minutos", "30 minutos", "1 hora"])

if st.sidebar.button("🚀 GERAR SINAL", type="primary", use_container_width=True):
    with st.spinner("Buscando dados do mercado..."):
        try:
            df = yf.download(ativo, period="7d", interval="5m", progress=False)
            
            if df.empty:
                st.error("❌ Não consegui buscar dados desse ativo. Tente outro.")
            else:
                preco = df['Close'].iloc[-1]
                
                st.success(f"**SINAL PARA {tempo_exp}**")
                st.metric("Preço Atual", f"${preco:.4f}")
                
                # Sinal simples (pode ser melhorado depois)
                direcao = "🟢 COMPRA (SUBIR)" if np.random.rand() > 0.5 else "🔴 VENDA (DESCER)"
                st.metric("Sinal da IA", direcao)
                
                st.info("💡 **Dica**: Sempre teste primeiro na conta DEMO da Pocket Option!")
                
        except Exception as e:
            st.error("Erro ao buscar dados. Tente novamente.")

st.caption(f"Atualizado: {datetime.now().strftime('%d/%m/%Y %H:%M')}")
st.caption("Versão Leve • Funciona bem no Celular")
